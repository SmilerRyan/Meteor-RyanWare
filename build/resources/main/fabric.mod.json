{
  "schemaVersion": 1,
  "id": "ryanware",
  "version": "0.1",
  "name": "Meteor Client (RyanWare Add-On)",
  "description": "Just another Addon for the Meteor Client.",
  "authors": ["SmilerRyan"],
  "contact": {
    "repo": "https://github.com/smilerryan/meteor-ryanware"
  },
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "smilerryan.ryanware.RyanWare"
    ]
  },
  "mixins": [
    "ryanware.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "229,255,0",
    "github:sha": ""
  },
  "depends": {
    "java": ">=17",
    "minecraft": ">=1.20.6",
    "meteor-client": "*"
  }
}
