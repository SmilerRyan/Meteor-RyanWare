{
  "schemaVersion": 1,
  "id": "ryanware",
  "version": "6.7",
  "name": "Johny Client",
  "icon": "icons/johny_pork.jpg",
  "description": "Just another Addon for the Meteor Client.",
  "authors": ["SmilerRyan", "ChatGPT"],
  "contact": {
    "repo": "https://github.com/smilerryan/meteor-ryanware"
  },
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "smilerryan.ryanware.RyanWare"
    ]
  },
  "mixins": [
    "ryanware.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "229,255,0",
    "github:sha": "",
    "ryanware:addon-name": "Johny Client",
    "ryanware:module-prefix-extras": "Johny-+-",
    "ryanware:module-prefix-standard": "Johny-Pork-",
    "ryanware:cat-name-extras": "Johny Plus",
    "ryanware:cat-name-standard": "Johny Pork",
    "ryanware:icon-extras": "porkchop",
    "ryanware:icon-standard": "cooked_porkchop"
  },
  "depends": {
    "java": ">=17",
    "minecraft": ">=1.20.6",
    "meteor-client": "*"
  }
}
