{
  "schemaVersion": 1,
  "id": "ryanware",
  "version": "0.1",
  "name": "NovaCore",
  "icon": "icon-plus.png",
  "description": "The NovaCore Addon for Meteor Client.",
  "authors": ["ChatGPT"],
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "smilerryan.ryanware.RyanWare"
    ]
  },
  "mixins": [
    "ryanware.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "229,255,0",
    "github:sha": "",
    "ryanware:addon-name": "NovaCore",
    "ryanware:module-prefix-essentials": "Nova-",
    "ryanware:module-prefix-extras": "WIP-",
    "ryanware:module-prefix-3": "3-",
    "ryanware:cat-name-essentials": "NovaCore",
    "ryanware:cat-name-extras": "NovaBeta",
    "ryanware:cat-name-3": "Nova3",
    "ryanware:icon-essentials": "nether_star",
    "ryanware:icon-extras": "flint_and_steel",
    "ryanware:icon-3": "sponge"
  },
  "depends": {
    "java": ">=17",
    "minecraft": ">=1.20.6",
    "meteor-client": "*"
  }
}
