{
  "schemaVersion": 1,
  "id": "ryanware",
  "version": "${version}",
  "name": "RyanWare",
  "icon": "icon.png",
  "description": "Just another Addon for the Meteor Client.",
  "authors": ["SmilerRyan"],
  "contact": {
    "repo": "https://github.com/smilerryan/meteor-ryanware"
  },
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "smilerryan.ryanware.RyanWare"
    ]
  },
  "mixins": [
    "ryanware.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "229,255,0",
    "github:sha": "@gh_hash@",
    "ryanware:addon-name": "RyanWare",
    "ryanware:module-prefix-essentials": "RyanWare-E-",
    "ryanware:module-prefix-extras": "RyanWare-+-",
    "ryanware:cat-name-essentials": "RyanWare Essentials",
    "ryanware:cat-name-extras": "RyanWare Extras",
    "ryanware:icon-essentials": "sponge",
    "ryanware:icon-extras": "sponge"
  },
  "depends": {
    "java": ">=17",
    "minecraft": ">=@mc_version@",
    "meteor-client": "*"
  }
}
