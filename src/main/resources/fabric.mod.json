{
  "schemaVersion": 1,
  "id": "ryanware",
  "version": "2.2",
  "name": "Shadow Client",
  "icon": "icon-d.png",
  "description": "Just another Addon for the Meteor Client.",
  "authors": ["SmilerRyan"],
  "contact": {
    "repo": "https://github.com/smilerryan/meteor-shadow-client"
  },
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "smilerryan.ryanware.RyanWare"
    ]
  },
  "mixins": [
    "ryanware.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "229,255,0",
    "github:sha": "",
    "ryanware:addon-name": "ShadowClient",
    "ryanware:module-prefix-essentials": "Shadow-",
    "ryanware:module-prefix-extras": "Shadow-",
    "ryanware:module-prefix-3": "Shadow3-",
    "ryanware:cat-name-essentials": "Shadow",
    "ryanware:cat-name-extras": "ShadowPlus",
    "ryanware:cat-name-3": "Shadow3",
    "ryanware:icon-essentials": "ender_pearl",
